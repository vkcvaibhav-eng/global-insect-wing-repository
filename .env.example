# Local demonstration database. Use an absolute path if running commands from
# outside the repository root.
DATABASE_URL=sqlite:///data/wing_repository.db
WBR_DATA_DIR=data
WBR_MAX_UPLOAD_MB=25
WBR_AUTO_BOOTSTRAP_DEMO=false

# Demo-only account passwords consumed by scripts/seed_demo.py.
# Change these before seeding; never commit real credentials.
WBR_DEMO_ADMIN_PASSWORD=change-this-admin-password
WBR_DEMO_STUDENT_PASSWORD=change-this-student-password
WBR_DEMO_REVIEWER_PASSWORD=change-this-reviewer-password

# Production example:
# DATABASE_URL=postgresql+psycopg://user:password@db.example.org/wing_repository
