# Local development database. Use an absolute path if running commands from
# outside the repository root. Hosted deployments should use PostgreSQL.
DATABASE_URL=sqlite:///data/wing_repository.db
WBR_STORAGE_BACKEND=local
WBR_DATA_DIR=data
WBR_MAX_UPLOAD_MB=25

# First real administrator bootstrap. Use your own institutional/Gmail address.
# Never commit real credentials; keep them in .env locally or Streamlit secrets.
WBR_BOOTSTRAP_ADMIN_EMAIL=curator@institute.edu
WBR_BOOTSTRAP_ADMIN_FULL_NAME=Institute Curator
WBR_BOOTSTRAP_ADMIN_PASSWORD=change-this-long-admin-password
WBR_BOOTSTRAP_ADMIN_RESET_PASSWORD=false

# Optional published Apis reference-analysis inputs. These directories should
# contain manually downloaded research datasets/workflows and must not be
# committed to GitHub.
# WBR_OLEKSA_REFERENCE_DIR=reference-data/oleksa-zenodo-7244070
# WBR_NAWROCKA_REFERENCE_DIR=reference-data/nawrocka-zenodo-7567336
# WBR_APIS_WORKFLOW_DIR=reference-data/workflowhub-422
# WBR_ANALYSIS_ARTIFACT_DIR=data/analysis-artifacts

# Production example:
# DATABASE_URL=postgresql+psycopg://user:password@db.example.org/wing_repository
# WBR_STORAGE_BACKEND=r2
# WBR_R2_ENDPOINT_URL=https://<account-id>.r2.cloudflarestorage.com
# WBR_R2_BUCKET_NAME=wing-originals
# WBR_R2_ACCESS_KEY_ID=<r2-access-key-id>
# WBR_R2_SECRET_ACCESS_KEY=<r2-secret-access-key>
# WBR_R2_KEY_PREFIX=originals/
